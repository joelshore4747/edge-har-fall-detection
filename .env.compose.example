# Docker Compose deployment settings.
POSTGRES_DB=vulnerability_dissertation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

API_PORT=8000
# Start with 2 workers in production, then adjust only if RAM allows.
API_WORKERS=2
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=/app/logs/runtime_api.log
LOG_FAILURE_FILE_PATH=/app/logs/runtime_api_failures.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
AUTH_REQUIRED=true
# Self-service registration is OFF by default. Only enable this if you have
# also configured rate limiting (RATE_LIMIT_REGISTRATION_PER_MINUTE) and
# tightened CORS_ALLOW_ORIGINS to your real origins.
SELF_SERVICE_REGISTRATION_ENABLED=false
RATE_LIMIT_REGISTRATION_PER_MINUTE=5
UVICORN_ACCESS_LOG=false
ADMIN_WEB_ENABLED=true
ADMIN_SESSION_SECRET=change-this-to-a-long-random-string-of-at-least-32-chars
ADMIN_SESSION_HTTPS_ONLY=true

# Optional one-off admin bootstrap profile:
# docker compose --env-file .env.compose --profile bootstrap up admin-bootstrap
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

# Set this to your origin(s) before exposing the admin app or API.
# A wildcard ("*") disables credentialed CORS and is unsafe with cookie auth.
CORS_ALLOW_ORIGINS=https://example.com

# Admin web build settings. Empty VITE_API_BASE_URL means same-origin /v1 calls.
VITE_DEMO_MODE=false
VITE_API_BASE_URL=

# These paths are resolved inside the container.
HAR_ARTIFACT_PATH=/app/artifacts/har/runtime_v1.joblib
FALL_ARTIFACT_PATH=/app/artifacts/fall/fall_meta_phone_negatives_v2/model.joblib
FEEDBACK_STORE_PATH=/app/artifacts/feedback/prediction_feedback.jsonl
SESSION_STORAGE_DIR=/app/artifacts/runtime_sessions
ADMIN_WEB_DIST_PATH=/app/apps/admin/dist
