# Local shell / non-Docker backend settings.
# For Docker Compose deployment, copy `.env.compose.example` to `.env.compose`.

# PostgreSQL connection used by the production-facing backend and future DB logging.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vulnerability_dissertation

# Comma-separated origins allowed to call the API from the mobile/web clients.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

# Use absolute paths in deployed environments.
HAR_ARTIFACT_PATH=artifacts/har/runtime_v1.joblib
FALL_ARTIFACT_PATH=artifacts/fall/fall_meta_phone_negatives_v2/model.joblib
FEEDBACK_STORE_PATH=artifacts/feedback/prediction_feedback.jsonl
SESSION_STORAGE_DIR=artifacts/runtime_sessions

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/runtime_api.log
LOG_FAILURE_FILE_PATH=logs/runtime_api_failures.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
API_HOST=0.0.0.0
API_PORT=8000
AUTH_REQUIRED=false
SELF_SERVICE_REGISTRATION_ENABLED=false
UVICORN_ACCESS_LOG=false
